{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AgentResponse",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "status": {
      "type": "string",
      "enum": [
        "success",
        "partial",
        "error"
      ]
    },
    "message": {
      "type": "string"
    },
    "data": {
      "type": "object"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "agent_slug": {
          "type": "string"
        },
        "agent_version": {
          "type": "string"
        },
        "run_id": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": [
        "agent_slug",
        "agent_version",
        "run_id"
      ]
    }
  },
  "required": [
    "status",
    "message",
    "data",
    "metadata"
  ]
}
